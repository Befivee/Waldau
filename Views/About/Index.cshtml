@{
    ViewData["Title"] = "О нас";
    ViewData["MetaDescription"] = "Замок Вальдау: история крепости, семья Сорокиных, команда и люди, которые создают атмосферу для гостей.";

    var teamMembers = new (string Name, string PhotoBase, string Bio)[]
    {
        (
            "Надежда",
            "images/AboutUs/Надежда2",
            "Хозяйка замка. У каждой крепости была своя хозяйка — та, что заботилась о тепле, уюте и том, чем заняться гостям. В XXI веке эту роль в Вальдау несёт Надежда Сорокина: двенадцать лет назад ей пришла идея заняться замком XIII века. Сегодня она организует съёмки, ищет новые смыслы для старых стен и занимается «сказочными делами» замка."
        ),
        ("Сергей", "images/AboutUs/Сергей3", "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore."),
        ("Савелий", "images/AboutUs/Савелий4", "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ut enim ad minim veniam, quis nostrud."),
        ("Павел", "images/AboutUs/Павел5", "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Duis aute irure dolor in reprehenderit."),
        ("Елена", "images/AboutUs/Елена6", "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Excepteur sint occaecat cupidatat non proident."),
        ("Персик", "images/AboutUs/Персик7", "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed ut perspiciatis unde omnis iste natus."),
    };
}

<section class="page-hero page-hero--compact" aria-labelledby="page-title">
    <partial name="_PageHeroPhoto" model="@(new PageHeroPhotoViewModel("images/AboutUs/О нас1", "page-hero__bg--about"))" />
    <div class="container-xl page-hero__content reveal">
        <h1 id="page-title" class="page-hero__title">О нас</h1>
        <p class="page-hero__lead">Крепость XIII века в сердце Натангии</p>
    </div>
</section>

<section class="section">
    <div class="container-xl">
        <div class="about-split reveal">
            <div class="about-split__image about-split__image--castle" role="img" aria-label="Руины замка Вальдау"></div>
            <div class="about-split__text">
                <h2>Живая история</h2>
                <p>Замок Вальдау — один из немногих сохранившихся замков Калининградской области. Основанный около 1258 года, он служил форпостом Тевтонского ордена и пережил века войн и реконструкций.</p>
                <p>Сегодня на территории работает музей, проводятся экскурсии и тематические мероприятия для туристов и семей.</p>
            </div>
        </div>

        <div class="about-features">
            <article class="about-feature reveal">
                <h3>Архитектура</h3>
                <p>На данный момент один из самых сохранившихся замков Калининграда. Перекрытия, несущие стены, деревянные окна и многое другое сохранилось со времён XIII века.</p>
            </article>
            <article class="about-feature reveal">
                <h3>Семья Сорокиных</h3>
                <p>Семья Сорокиных занимается восстановлением замка с 2014 года. Благодаря их труду и заботе Вальдау снова открыт для гостей и живёт полноценной жизнью.</p>
            </article>
            <article class="about-feature reveal">
                <h3>Экскурсии</h3>
                <p>Обзорные, семейные и вечерние программы с опытными гидами.</p>
            </article>
        </div>

        <header class="section-header reveal">
            <h2 class="section-header__title">Наша семья</h2>
            <p class="section-header__lead">Люди, которые встречают гостей и берегут историю замка</p>
        </header>

        <div class="team-grid">
            @foreach (var member in teamMembers)
            {
                <article class="team-card reveal">
                    <div class="team-card__photo" style="@StaticImageCss.BackgroundImageSet(Url, member.PhotoBase)" role="img" aria-label="@member.Name"></div>
                    <div class="team-card__body">
                        <h3 class="team-card__name">@member.Name</h3>
                        <p class="team-card__bio">@member.Bio</p>
                    </div>
                </article>
            }
        </div>

        <div class="section-cta reveal">
            <button type="button" class="btn btn-primary btn-lg" data-booking-open>Записаться на экскурсию</button>
        </div>
    </div>
</section>
