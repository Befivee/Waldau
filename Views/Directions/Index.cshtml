@{
    ViewData["Title"] = "Как добраться";
}

<section class="page-hero page-hero--compact" aria-labelledby="page-title">
    <partial name="_PageHeroPhoto" model="@(new PageHeroPhotoViewModel("images/All/как добраться", "page-hero__bg--directions"))" />
    <div class="container-xl page-hero__content reveal">
        <h1 id="page-title" class="page-hero__title">Как добраться</h1>
        <p class="page-hero__lead">@SiteInfo.DistanceFromKg · @SiteInfo.TravelTime</p>
    </div>
</section>

<section class="section">
    <div class="container-xl">
        <div class="directions-layout">
            <div class="directions-layout__map reveal">
                <partial name="_YandexMap" model="@("xl")" />
                <a href="@SiteInfo.YandexMapsUrl" target="_blank" rel="noopener" class="btn btn-primary btn-block">Открыть маршрут</a>
            </div>

            <div class="directions-layout__info">
                <article class="route-card reveal">
                    <span class="route-card__icon" aria-hidden="true">🚍</span>
                    <div>
                        <h2>@SiteInfo.BusRoute</h2>
                        <p>Отправление от автовокзала Калининграда на Автобусе 110. Остановка «Низовье» — 5 минут пешком до замка.</p>
                        <p class="route-card__meta">@SiteInfo.TravelTime · @SiteInfo.DistanceFromKg</p>
                    </div>
                </article>

                <article class="route-card reveal">
                    <span class="route-card__icon" aria-hidden="true">🚗</span>
                    <div>
                        <h2>На автомобиле</h2>
                        <p>По трассе в сторону пос. Низовье. Указатели на замок есть на подъезде к поселку.</p>
                        <p class="route-card__meta">~25 мин на автомобиле. Парковка у входа</p>
                    </div>
                </article>

                <article class="route-card reveal">
                    <span class="route-card__icon" aria-hidden="true">📍</span>
                    <div>
                        <h2>Адрес</h2>
                        <p>@SiteInfo.Address</p>
                    </div>
                </article>
            </div>
        </div>

        <div class="directions-entrance reveal">
            <div class="directions-entrance__image" style="@StaticImageCss.BackgroundImageSet(Url, "images/enter")" role="img" aria-label="Вход в замок Вальдау"></div>
            <div class="directions-entrance__text">
                <h2>Вход в замок</h2>
                <p>Главный вход в замок Вальдау — с улицы Замковой. Ориентир: кованые ворота и вывеска музея. Касса и начало экскурсий — у входа; приезжайте за 10–15 минут до назначенного времени.</p>
                <p class="directions-entrance__hint">На фото — вход, через который гости попадают на территорию крепости.</p>
            </div>
        </div>
    </div>
</section>
