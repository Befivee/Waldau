@model IReadOnlyList<Event>
@{
    ViewData["Title"] = "Администрирование — мероприятия";
    ViewData["BodyClass"] = "page-admin";
}

<section class="section">
    <div class="container-xl reveal">
        <header class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
            <div>
                <h1 class="section-header__title mb-1">Мероприятия</h1>
                <p class="section-header__lead mb-0">Управление событиями замка</p>
            </div>
            <a asp-action="Create" class="btn btn-primary">Добавить мероприятие</a>
        </header>

        @if (TempData["AdminMessage"] is string message)
        {
            <div class="alert alert-success" role="status">@message</div>
        }

        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle admin-table">
                <thead class="table-dark">
                    <tr>
                        <th scope="col">#</th>
                        <th scope="col">Изображение</th>
                        <th scope="col">Название</th>
                        <th scope="col">Дата</th>
                        <th scope="col" class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var evt in Model)
                    {
                        <tr>
                            <td>@evt.Id</td>
                            <td>
                                <img src="@evt.DisplayImagePath" alt="" class="admin-table__thumb" width="64" height="48" />
                            </td>
                            <td>@evt.Title</td>
                            <td>@evt.EventDate.ToString("d MMMM yyyy", new System.Globalization.CultureInfo("ru-RU"))</td>
                            <td class="text-end text-nowrap">
                                <a asp-action="Edit" asp-route-id="@evt.Id" class="btn btn-sm btn-outline-primary">Изменить</a>
                                <a asp-action="Delete" asp-route-id="@evt.Id" class="btn btn-sm btn-outline-danger">Удалить</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <p class="empty-state">Мероприятий пока нет. <a asp-action="Create">Создайте первое</a>.</p>
        }

        <p class="mt-4"><a asp-controller="Home" asp-action="Index" class="link-arrow">← На сайт</a></p>
    </div>
</section>
