@model Event

<article class="event-card reveal">
    <div class="event-card__image" style="--card-bg: url('@Model.DisplayImagePath')"></div>
    <div class="event-card__body">
        <time class="event-card__date" datetime="@Model.EventDate.ToString("yyyy-MM-dd")">
            @Model.EventDate.ToString("d MMMM yyyy", new System.Globalization.CultureInfo("ru-RU"))
        </time>
        <h3 class="event-card__title">@Model.Title</h3>
        <p class="event-card__desc">@Model.Description</p>
        <button type="button" class="btn btn-primary btn-sm" data-booking-open>
            Записаться
        </button>
    </div>
</article>
