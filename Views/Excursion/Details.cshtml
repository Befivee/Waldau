@model Excursion
@{
    ViewData["Title"] = Model.Title;
}

<section class="page-hero page-hero--compact" aria-labelledby="page-title">
    <div class="page-hero__bg" style="background-image: url('/images/tour-placeholder.svg')"></div>
    <div class="container-xl page-hero__content reveal">
        <h1 id="page-title" class="page-hero__title">@Model.Title</h1>
        <p class="page-hero__lead">@Model.Duration · @Model.Price.ToString("0") ₽</p>
    </div>
</section>

<section class="section">
    <div class="container-xl content-narrow reveal">
        <p class="lead-text">@Model.Description</p>
        <div class="detail-actions">
            <a asp-controller="Booking" asp-action="Create"
               asp-route-excursionId="@Model.Id"
               asp-route-excursionTitle="@Model.Title"
               class="btn btn-primary">Записаться</a>
            <button type="button" class="btn btn-outline" data-booking-open data-tour-id="@Model.Id" data-tour-name="@Model.Title">Быстрая запись</button>
            <a asp-controller="Excursion" asp-action="Index" class="btn btn-outline">Все экскурсии</a>
        </div>
    </div>
</section>
