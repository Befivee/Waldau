@model IReadOnlyList<ExcursionTypeInfo>
@{
    ViewData["Title"] = "Экскурсии";
}

<section class="page-hero page-hero--compact" aria-labelledby="page-title">
    <partial name="_PageHeroPhoto" model="@(new PageHeroPhotoViewModel("images/All/Экскурсии"))" />
    <div class="container-xl page-hero__content reveal">
        <h1 id="page-title" class="page-hero__title">Экскурсии</h1>
        <p class="page-hero__lead">Два формата посещения замка — выберите подходящий и оставьте заявку</p>
    </div>
</section>

<section class="section" aria-label="Виды экскурсий">
    <div class="container-xl">
        <div class="excursion-types">
            @foreach (var excursion in Model)
            {
                <partial name="Components/_ExcursionTypeBlock" model="excursion" />
            }
        </div>

        <partial name="Components/_ExcursionPricing" />
    </div>
</section>
