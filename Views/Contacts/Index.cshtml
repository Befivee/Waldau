@{
    ViewData["Title"] = "Контакты";
}

<section class="page-hero page-hero--compact" aria-labelledby="page-title">
    <partial name="_PageHeroPhoto" model="@(new PageHeroPhotoViewModel("images/All/Контакты", "page-hero__bg--contacts"))" />
    <div class="container-xl page-hero__content reveal">
        <h1 id="page-title" class="page-hero__title">Контакты</h1>
        <p class="page-hero__lead">Свяжитесь с нами или запишитесь на экскурсию</p>
    </div>
</section>

<section class="section">
    <div class="container-xl">
        <div class="contacts-grid">
            <div class="contacts-info reveal">
                <div class="contact-block">
                    <h2>Телефон</h2>
                    <a href="tel:@SiteInfo.PhoneTel" class="contact-block__value">@SiteInfo.Phone</a>
                </div>
                <div class="contact-block">
                    <h2>Дополнительный телефон</h2>
                    <a href="tel:@SiteInfo.Phone2Tel" class="contact-block__value">@SiteInfo.Phone2</a>
                </div>
                <div class="contact-block">
                    <h2>Адрес</h2>
                    <p class="contact-block__value">@SiteInfo.Address</p>
                </div>
                <div class="contact-block">
                    <h2>Режим работы</h2>
                    <p class="contact-block__value">@SiteInfo.WorkingHours</p>
                </div>
                <partial name="_SocialLinks" />
                <button type="button" class="btn btn-primary btn-lg contacts-info__cta" data-booking-open>Записаться на экскурсию</button>
            </div>
            <div class="contacts-map reveal">
                <partial name="_YandexMap" model="@("lg")" />
                <a href="@SiteInfo.YandexMapsUrl" target="_blank" rel="noopener" class="link-arrow">Открыть в Яндекс.Картах</a>
            </div>
        </div>
    </div>
</section>
